# Copiá este archivo a ".env" en la VM y completá los valores.

# Tu subdominio gratis de DuckDNS (apuntando a la IP pública de la VM).
DOMAIN=TUNOMBRE.duckdns.org

# Email para los avisos del certificado (Let's Encrypt).
ACME_EMAIL=nico.palermo@gmail.com

# Admin inicial de la app (se siembra solo al arrancar).
ADMIN_EMAIL=nico.palermo@gmail.com

# Tope de tamaño por descarga en MB (0 = sin tope).
MAX_FILESIZE_MB=0
